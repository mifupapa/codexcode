# Google Cloud Vision API (OCR用)
# Google Cloud Console でサービスアカウントキーをダウンロードし、パスを設定
GOOGLE_APPLICATION_CREDENTIALS=credentials/service_account.json

# Google Drive OAuth2 (Drive保存用)
# Google Cloud Console で OAuth2 クライアントIDを作成し、ダウンロードしたJSONのパスを設定
GOOGLE_OAUTH2_CLIENT_SECRETS=credentials/client_secret.json

# アプリ設定
APP_HOST=127.0.0.1
APP_PORT=8000
DATA_DIR=data

# OCRエンジン選択: "vision" (Google Cloud Vision) または "tesseract" (オフライン)
OCR_ENGINE=vision

# TTSエンジン選択: "aivis" (AivisSpeech高品質) または "gtts" (gTTS無料オンライン)
TTS_ENGINE=aivis

# AivisSpeech設定
AIVIS_HOST=http://127.0.0.1:10101
AIVIS_SPEAKER=0
